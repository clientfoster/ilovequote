PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=ilovequote
PUBLIC_BASE_URL=http://localhost:3001
FRONTEND_BASE_URL=http://localhost:3000
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Your App <no-reply@yourdomain.com>

# Firebase Admin for phone OTP verification.
# Preferred on Render: paste the full service account JSON as one env value.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"pricequote-38d5c"}

# Alternative if you do not use FIREBASE_SERVICE_ACCOUNT_JSON:
FIREBASE_PROJECT_ID=pricequote-38d5c
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@pricequote-38d5c.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
